# ============================================
# AUTENTICAÇÃO CLAUDE (escolha UMA opção)
# ============================================

# OPÇÃO 1: API Key (pague por uso via API)
ANTHROPIC_API_KEY=sk-ant-...

# OPÇÃO 2: OAuth (use sua assinatura Claude Pro/Max)
# Registre um app em https://console.anthropic.com/settings/oauth
# e preencha as credenciais abaixo. Após iniciar o bot, envie "oauth"
# pelo WhatsApp para conectar sua conta.
#CLAUDE_OAUTH_CLIENT_ID=
#CLAUDE_OAUTH_CLIENT_SECRET=
#CLAUDE_OAUTH_REDIRECT_URI=https://localhost/oauth/callback
#CLAUDE_OAUTH_AUTH_URL=https://auth.anthropic.com/authorize
#CLAUDE_OAUTH_TOKEN_URL=https://auth.anthropic.com/oauth/token
#CLAUDE_OAUTH_SCOPES=user:inference

# Modelo Claude
CLAUDE_MODEL=claude-sonnet-4-6

# ============================================
# OPENAI (usado APENAS para visão, áudio e TTS)
# ============================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ============================================
# CONFIGURAÇÃO GERAL
# ============================================

# Identificação do master (com código do país, sem +)
MASTER_PHONE=5545999999999

# Limites
MAX_TOOL_ITERATIONS=10
DEBOUNCE_SECONDS=13
MEMORY_MAX_MESSAGES=100
