# ============================================
# AUTENTICAÇÃO CLAUDE
# ============================================

# Chave da API Anthropic (obrigatória)
ANTHROPIC_API_KEY=sk-ant-...

# Modelo Claude
CLAUDE_MODEL=claude-sonnet-4-6

# ============================================
# OPENAI (usado APENAS para visão, áudio e TTS)
# ============================================
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ============================================
# CONFIGURAÇÃO GERAL
# ============================================

# Identificação do master (com código do país, sem +)
MASTER_PHONE=5545999999999

# Limites
MAX_TOOL_ITERATIONS=10
DEBOUNCE_SECONDS=13
MEMORY_MAX_MESSAGES=100
